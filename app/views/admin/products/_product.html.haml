%td
  - page = params[:page].blank? ? 1 : params[:page].to_i
  = (i+1) + 20*(page-1)
%td{style: "width: 60px"}
  = image_tag product.image, size: "32x32"
%td= product.title
%td= product.category_path
%td= product.created_at.strftime("%d %b, %y")
%td= link_to product.user.email, "#profile-#{product.user.profile_id}", data: {toggle: 'modal'}
%td= product.rental_status
%td.avail{style: "width: 80px"}= render partial: "avail_toggle", locals: {product: product}

%td.closest.text-center
  = check_box_tag :available, product.featured,  product.featured?, class: "featured-toggle", data: {id: product.id}
  %span.update-msg{style: "color: green;"}
  %span.update-error{style: "color: red;"}
%td{style: "width: 90px"}
  = link_to user_product_path(product), class: "btn btn-sm btn-success edit-product", target: "_blank" do
    %span.glyphicon.glyphicon-eye-open
  = link_to edit_product_path(product), class: "btn btn-sm btn-success", target: "_blank" do
    %span.glyphicon.glyphicon-pencil

= render partial: "/admin/users/profile", locals: {profile: product.user.profile}
