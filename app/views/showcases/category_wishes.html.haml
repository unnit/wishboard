.container-fluid.ptop50.padding0.mob-ptop100.min-height1000{style: "background:#ebeced;"}
  .container.padding0.mtop20
    - @category_wishes.each do |category_wish|
      .col-xs-12.col-sm-3.padding8
        .col-xs-12.col-sm-12.bg-white.no-mar-pad.border-medium.border5
          .pull-left.full-width.text-center
            = cl_image_tag category_wish.image, class: "img-responsive inline-display", width: 300, height: 225, crop: :fill, gravity: :face, alt: category_wish.title
          .pull-left.full-width.padding10.font20.weight600
            = truncate category_wish.title, length: 28
          .pull-left.full-width.mbottom5.padding10.font12
            = truncate category_wish.description, length: 180
          .pull-left.full-width.text-center.padding10
            = link_to edit_category_wish_showcase_path(category_wish), remote: true do
              .btn.btn-v-outline.btn-md.transition-effect
                Wish
