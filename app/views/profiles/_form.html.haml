.panel.panel-primary.collbod#profile_form
  .collbocol.panel-heading{:style => "background-color:#e84242; border: none;"}
    %h3.panel-title.about-text Profile Info
    %span.pull-right.clickable
      %i.glyphicon.glyphicon-chevron-up
  .row.panel-body
    .col-md-12
      ~ form_for @profile, html: {class: 'form-horizontal profile_form', role: "form"} do |f|
        .errors= render partial: "/layouts/errors", locals: {errors: @profile.errors.full_messages}
        %fieldset
          .form-group
            .col-sm-4
              %h3.mtop10 You
          .form-group
            %label.col-sm-2.control-label{:for => "textinput"} First Name
            .col-sm-3
              = f.text_field :first_name, :placeholder => "First Name", class: "form-control", maxlength: 200
            %label.col-sm-2.control-label{:for => "textinput"} Last Name
            .col-sm-3
              = f.text_field :last_name, :placeholder => "Last Name", class: "form-control", maxlength: 200
          .form-group
            %label.col-sm-2.control-label{:for => "textinput"} Phone No
            .col-sm-3
              = f.text_field :phone, :placeholder => "Phone No", class: "form-control", maxlength: 10
          .form-group
            %label.col-sm-2.control-label{:for => "textinput"} About
            .col-sm-6
              = f.text_area :about, class: "form-control textarea", row: "5", placeholder: "About You", maxlength: 1000
          .form-group
            %label.col-sm-2.control-label{:for => "textinput"} Profile Pic
            .col-sm-10
              #fileupload.fileinput-button.upload-image-placeholder
                .fileupload-text-container
                  .fileupload-centered-text
                    .fileupload-text Select file
                    .fileupload-small-text
                = f.file_field :image, style: "display: inline-block;" , class: "fileupload"
                %span.avatar-preview= render partial: "/profiles/avatar"
                .fileupload-preview-remove-image
                  %i.icon-remove.icon-fix
                %input.listing-image-id{:name => "listing_images[][id]", :type => "hidden"}
          .form-group
            .col-sm-4
              %h3.mtop10 Address
          = fields_for 'address' do |af|
            .form-group
              %label.col-sm-2.control-label Address Line 1
              .col-sm-4= af.text_field :address1, class: "form-control", required: true, placeholder: "Flat/House No, Floor, Building"
            .form-group
              %label.col-sm-2.control-label Address Line 2
              .col-sm-4= af.text_field :address2, class: "form-control", required: true, placeholder: "Colony/Society, Street, Locality/Area"
            .form-group
              %label.col-sm-2.control-label Town/City
              .col-sm-4= af.text_field :city, class: "form-control city", required: true
            .form-group
              %label.col-sm-2.control-label State
              .col-sm-4
                = af.select :state, options_for_select(india_states), {prompt: 'State'}, class: "select_box state selectpicker"
            .form-group
              %label.col-sm-2.control-label Pincode
              .col-sm-4= af.text_field :zip, class: "form-control check_zip", required: true
          .form-group
            .col-sm-4
              %h3.mtop10 Availability
          .form-group
            %label.col-sm-2.control-label.mtop5{:for => "textinput"} Days available
            .col-sm-10.mtop10
              - Date::DAYNAMES.each_with_index do |day, i|
                %span.mleft15
                  = check_box_tag "profile[avail_days][]", i, @profile.avail_days_arr.include?(i.to_s), class: "styled", id: "#{day}"
                  %label{:for => "#{day}"}= day
          .form-group
            %label.col-sm-2.control-label{:for => "textinput"} Open Time
            .col-sm-4
              = f.select :open_time, options_for_select(Profile.create_open_close_time, @profile.open_time), {}, class: "selectpicker"
          .form-group
            %label.col-sm-2.control-label{:for => "textinput"} Close Time
            .col-sm-4
              = f.select :close_time, options_for_select(Profile.create_open_close_time, @profile.close_time), {}, class: "selectpicker"
          .form-group
            .col-sm-offset-2.col-sm-10
              .pull-right
                %button.btn.btn-info.save-button Save Information
