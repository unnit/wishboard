!!!
%html
  %head
    %meta{name: "viewport", content: "width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no"}
    %meta{:charset => "utf-8"}
    %meta{:content => "IE=edge", "http-equiv" => "X-UA-Compatible"}
    %meta{:content => "width=device-width, initial-scale=1", :name => "viewport"}
    %link{rel: "icon", type: "image/x-icon", href: "/favicon.ico"}
    - if Rails.env.development? || request.fullpath == GLOBAL_VARIABLES[:hacker_relative_path]
      %meta{:name => "robots", :content => "noindex"}
    %meta{:content => "#{content_for?(:meta_content) ? yield(:meta_content) : 'Wishboard is a social network based on wishes. Make new friends, discuss, discover, share wishes, get free gifts, & raise funds to fulfill your wishes.'}", :name => "description"}
    %meta{:content => "", :name => "author"}
    %meta{name: "msapplication-TileColor", content: "#732db0"}
    %meta{name: "image", content: "#{GLOBAL_VARIABLES[:root_url]}/assets/logo.png"}
    %meta{itemprop: "name", content: "#{content_for?(:title) ? yield(:title) : "Wishboard | Share, find, fund & fulfill your wishes."}"}
    %meta{itemprop: "description", content: "#{content_for?(:meta_content) ? yield(:meta_content) : 'Wishboard is a social network based on wishes. Make new friends, discuss, discover, share wishes, get free gifts, & raise funds to fulfill your wishes.'}"}
    %meta{itemprop: "image", content: "#{GLOBAL_VARIABLES[:root_url]}/assets/logo.png"}
    %meta{name: "og:title", content: "#{content_for?(:title) ? yield(:title) : "Wishboard | Share, find, fund & fulfill your wishes."}"}
    %meta{name: "og:description", content: "#{content_for?(:meta_content) ? yield(:meta_content) : 'Wishboard is a social network based on wishes. Make new friends, discuss, discover, share wishes, get free gifts, & raise funds to fulfill your wishes.'}"}
    %meta{name: "og:image", content: "#{GLOBAL_VARIABLES[:root_url]}/assets/logo.png"}
    %meta{name: "og:url", content: "#{GLOBAL_VARIABLES[:root_url]}"}
    %meta{name: "og:site_name", content: "Wishboard"}
    %title= content_for?(:title) ? yield(:title) : "Wishboard | Share, find, fund & fulfill your wishes."
    

    / HTML5 shim and Respond.js IE8 support of HTML5 elements and media queries
    /[if lt IE 9]
      = javascript_include_tag "//oss.maxcdn.com/html5shiv/3.7.2/html5shiv.min.js", "//oss.maxcdn.com/respond/1.4.2/respond.min.js"
    = stylesheet_link_tag "//fonts.googleapis.com/css?family=Open+Sans:400,600"
    %link{rel: "manifest", href: "/assets/service-worker/manifest.json"}
    = stylesheet_link_tag 'application', media: 'all'
    = csrf_meta_tags
    - if @social_layout.present?
      %meta{name: "theme-color", content: "#732db0"}
    - elsif @auth_layout.present?
      %meta{name: "theme-color", content: "#0891e6"}
  %body{"data-root-url" => "#{GLOBAL_VARIABLES[:root_url]}", "data-logged-in-id" => "#{current_user.present? ? current_user.id : ''}"}
    #j-overlay-wrapper.overlay-wrapper.visible-xs{style: "display: none !important;"}
    #j-page-loader.top-page-loader{style: "display: none !important;"}
    - if Rails.env.production?
      = render partial: "/layouts/head"
      = render partial: "/layouts/google_analytics"
    - if @social_layout.present?
      = render partial: "/layouts/navbar_social"
    - elsif @plain_layout.present?
      = render partial: "/layouts/navbar_plain"
    - elsif @auth_layout.present?
      = render partial: "/layouts/navbar_auth"
    - elsif @special_layout.present?
      = render partial: "/layouts/navbar_special"
    - else
      = render partial: "/layouts/navbar_social"
    = render partial: "layouts/messages"
    = yield
    - if @remove_footer.blank?
      = render partial: "layouts/footer"
    - if Rails.env.production? || Rails.env.staging?
      =# render partial: "layouts/sentry_config"
    = javascript_include_tag "//maps.googleapis.com/maps/api/js?sensor=false&libraries=places&v=weekly&modules=places"
    = javascript_include_tag "//gstatic.com/firebasejs/4.1.3/firebase.js"
    = javascript_include_tag 'application'
    =# javascript_include_tag "//mocha.citruspay.com/js/lib/citrus.min.js"
    = yield :extra_js
    = javascript_include_tag "//apis.google.com/js/client.js"
    = cloudinary_js_config
