= content_for :title do
  - title = "Notifications | Cocociti"
.container-fluid.padding0.ptop50.mob-ptop100.bg-white.mbottom40{style: "min-height:700px;"}
  .container.padding0
    %h3.pleft-10 Your notifications
    .col-xs-12.col-sm-12.notif-full-content.no-mar-pad.mtop10
      = render partial: "layouts/web_notification_permission"
      - unless @notifications.blank?
        %span.full-width.pull-right
          = link_to update_all_notifications_path, remote: true do
            .col-xs-12.col-sm-12.padding5.text-right.cc-dark-fg.border-bt-side-dark
              Mark all as read
        = render partial: "home/notifications_content", locals: {notifications: @notifications}
      - else
        %h3.text-center No Activity yet???
    #infinite-scrolling-content.hidden
      = paginate @notifications, param_name: "notifications"
    .col-xs-12.col-sm-12.text-center.feed-loader.padding40{style: "display:none;"}
      %i.fa.fa-circle-o-notch.fa-spin.font21
      Please wait...
= content_for :extra_js do
  :javascript
    $(document).ready(function(){
      $(".notif-mob").addClass("cc-med-bg");
    })
