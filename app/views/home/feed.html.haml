.container-fluid.mtop50{style: "background-color: #f3f3f3"}
  .col-sm-3.hidden-xs.ptop10{style: "height: 1000px;"}
    .col-sm-12.no-mar-pad.border-left-band-profile.bg-shad.bg-white{style: "height: 215px;"}
      .col-sm-12{style: "height:108px;"}
      .col-sm-12{style: "height:108px;"}
        %span.mtop5.pull-left.font-bit-large.weight-bold{title: "#{current_user.name}", "data-toggle" => "tooltip", "data-placement" => "bottom", style: "margin-left: 95px;height: 40px;"}
          = (truncate current_user.profile.first_name, length: 20) || (truncate current_user.name, length: 20)
        .col-sm-12.no-mar-pad
          .col-sm-4.no-mar-pad
            %h6.no-mar-pad.weight-bold SHOWPIECES
            %h4= current_user.showcases.count
          .col-sm-4.no-mar-pad
            %h6.no-mar-pad.weight-bold FOLLOWING
            %h4.following-count= current_user.following.count
          .col-sm-4.no-mar-pad
            %h6.no-mar-pad.weight-bold FOLLOWERS
            %h4.followers-count= current_user.followers.count
      .col-sm-12{style: "margin-top: -148px;"}
        = link_to myprofile_path(current_user.profile.slug) do
          = cl_image_tag current_user.avatar, class: "img-circle pull-left", style: "border: 2px solid #fff;z-index: 1;position: relative;", width: 80, height: 80, crop: :fill
        %hr.pull-left.full-width.no-mar-pad{style: "margin-top: -40px;"}
  .col-xs-12.col-sm-6.no-mar-pad.ptop10{style: "border-top: 0px;"}
    .col-xs-12.col-sm-12.bg-white.padding10.mbottom10.border-left-band-action.bg-shad
      .col-xs-2.col-sm-1.no-mar-pad.full-height
        = link_to myprofile_path(current_user.profile.slug) do
          = cl_image_tag current_user.avatar, class: "img-circle", width: 40, height: 40, crop: :fill
      = form_for @showcase, url: showcases_path do |f|
        .col-xs-12.col-sm-2.no-mar-pad.text-center-mob{style: "overflow: hidden;height: 152px;"}
          .preview
          .glyphicon.glyphicon-remove.preview-delete.bg-white{style: "display: none;position: absolute;z-index: 1;"}
          .glyphicon.glyphicon-camera.file-input-button{style: "font-size: 65px;color: #E0E0E0;padding: 20px;border: 1px dotted;"}
            = cl_image_upload_tag(:image)
          .progress.progress-striped{style: "display: none;height: 10px;width:107px;"}
            .progress-bar{style: "width: 0%;"}
        .col-xs-12.col-sm-9.text-center.ptop10
          = f.text_field :title, placeholder: "Title", class: "form-control"
        .col-xs-12.col-sm-9.text-center.ptop10
          = f.text_area :description, placeholder: "Description", class: "form-control"
        .col-xs-4.col-sm-3.ptop10
          = f.text_field :year, placeholder: "Year", class: "form-control"
        .col-xs-8.col-sm-4.ptop10
          = f.fields_for :location do |lf|
            = lf.text_field :name, placeholder: "Location", class: "form-control"
        .col-xs-12.col-sm-12.mtop10.text-center
          = f.submit "Showcase", class: "btn btn-primary btn-shadow"
    .col-sm-12.no-mar-pad.showcase-strip
      = render partial: "showcases", locals: {showcases: @showcases}
    #infinite-scrolling-posts.hidden
      = paginate @showcases, param_name: "showcases"
      = hidden_field_tag :prev_showcase, @showcases.current_page - 1
  .col-sm-3.hidden-xs.ptop10{style: "height: 1000px;"}
    %h4 People to follow
    .col-sm-12.padding10.follow-wrapper.border-left-band-follow.bg-shad.bg-white{style: "height: 300px;overflow:hidden;"}
      .col-sm-12.no-mar-pad.follow-strip
        = render partial: "follow", locals: {users: @users}
      #infinite-scrolling-follow.hidden
        = paginate @users, param_name: "users"
      = hidden_field_tag :prev_user, @users.current_page - 1

= content_for :extra_js do
  :javascript
    $(document).ready(function(){
      $('.cloudinary-fileupload').bind('fileuploadprogress', function(e, data) {
        $('.progress').show();
        $('.progress-bar').css('width', Math.round((data.loaded * 100.0) / data.total) + '%');
      });
      $('.cloudinary-fileupload').bind('cloudinarydone', function(e, data) {
        $(".file-input-button, .progress").hide();
        $(".preview").show();
        $('.preview').html(
          $.cloudinary.image(data.result.public_id,
            { format: data.result.format, version: data.result.version,
              crop: 'fill', width: 150, height: 100 })
        );
        $('.progress-bar').css('width', '0%');
        $(".preview-delete").show();
        return true;
      });
      $(".preview-delete").click(function(){
        $(".preview-delete, .preview").hide();
        $(".file-input-button").show();
      })
      $(".follow-wrapper").mCustomScrollbar({
    					setHeight:330,
    					theme:"inset-2-dark",
              callbacks: {
                whileScrolling: function(){
                  if ($('#infinite-scrolling-follow').length) {
                    var more_posts_url = $('#infinite-scrolling-follow .pagination .next a').attr('href');
                    console.log(this.mcs.topPct)
                    if (more_posts_url && this.mcs.topPct == 100) {
                      $('#infinite-scrolling-follow .pagination').html('<img src="/assets/images/bx_loader-6d46e2cf165a5a0584afba7bc9663da292ee08c97cfc7613de6013ed05be892a.gif" alt="Loading..." title="Loading..." />');
                      $.getScript(more_posts_url+'&prev_user_page='+$("#prev_user").val()+'&prev_showcase_page='+$("#prev_showcase").val());
                    }
                  }
                }
              }
    	});
      if ($('#infinite-scrolling-posts').length) {
        $(window).on('scroll', function() {
          var more_posts_url = $('#infinite-scrolling-posts .pagination .next a').attr('href');
          if (more_posts_url && $(window).scrollTop() > $(document).height() - $(window).height() - 60) {
            $('#infinite-scrolling-posts .pagination').html('<img src="/assets/images/bx_loader-6d46e2cf165a5a0584afba7bc9663da292ee08c97cfc7613de6013ed05be892a.gif" alt="Loading..." title="Loading..." />');
            $.getScript(more_posts_url+'&prev_showcase_page='+$("#prev_showcase").val()+'&prev_user_page='+$("#prev_user").val());
          }
        });
      }
    });
