.container-fluid.bg-light-grey.ptop50.mob-ptop100.pbottom50
  .container.mtop10
    .row
      = render partial: "profiles/settings_layout"
      .col-md-9
        .panel.panel-default#profile_form
          .panel-heading
            %h4.mtop-v-5 Address Book
          .panel-body
            .col-sm-12
              ~ form_for @profile, url: update_social_profiles_path, html: {class: "form-horizontal"} do |f|
                .form-group
                  %label.col-sm-3.control-label Twitter
                  .col-sm-8= f.text_field :twitter, class: "form-control", placeholder: "Your Twitter URL", maxlength: 220
                .form-group
                  %label.col-sm-3.control-label Facebook
                  .col-sm-8= f.text_field :facebook, class: "form-control", placeholder: "Your Facebook URL", maxlength: 220
                .form-group
                  %label.col-sm-3.control-label Instagram
                  .col-sm-8= f.text_field :instagram, class: "form-control", placeholder: "Your Instagram URL", maxlength: 220
                .form-group
                  %label.col-sm-3.control-label Linkedin
                  .col-sm-8= f.text_field :linkedin, class: "form-control", placeholder: "Your Linkedin URL", maxlength: 220
                .form-group
                  %label.col-sm-3.control-label Google Plus
                  .col-sm-8= f.text_field :google_plus, class: "form-control", placeholder: "Your Google Plus URL", maxlength: 220
                .form-group
                  %label.col-sm-3.control-label Your/Company Website
                  .col-sm-8= f.text_field :website, class: "form-control", placeholder: "Your/Company Website full URL, eg: https://www.cocociti.com", maxlength: 220
                .form-group
                  %label.col-sm-3.control-label Other
                  .col-sm-8= f.text_field :other_url, class: "form-control", placeholder: "Any other profiles full URL, eg: https://www.cocociti.com", maxlength: 220
                .form-group
                  .col-xs-12.col-sm-12.text-center
                    = submit_tag "Save", class: "btn save-button mtop10 white-fg violet-bg border2 j-loader-trigger-link"
= content_for :extra_js do
  :javascript
    $(document).ready(function(){
      $(".soc-sett").addClass("active");
    });
