= content_for :extra_js do
  = javascript_include_tag "//icp.citruspay.com/js/citrus.js"
  = javascript_include_tag "//icp.citruspay.com/js/jquery.payment.min.js"
.container-fluid.aboutpad
  .container
    .col-sm-12
      %h3 Question about payments and refunds? Dial: 96 8686 0303
      = hidden_field_tag :id, @product.id
      .col-md-4.pull-right.no-mar-pad
        = image_tag @product.image, style: "width: 100%;"
        %h4.text-center= @product.title
        .col-md-12.mtop10.text-center{style: "font-weight: bold"}
          = @transaction.duration
        %hr.col-md-12.col-xs-12.mtop-v-5
        - days = (@transaction.enddate.to_date - @transaction.startdate.to_date).to_i
        - days = 1 if days < 1
        .col-md-12.summary-info= render partial: "price", locals: {product: @product, days: days}
        = hidden_field_tag :amount, @amount, id: "citrusAmount"
        = hidden_field_tag :coco_transaction_id, @transaction.coco_transaction_id, id: "citrusMerchantTxnId"
        = hidden_field_tag :signature, @transaction.security_signature, id: "citrusSignature"
        = hidden_field_tag :return_url, @return_url, id: "citrusReturnUrl"
        =# hidden_field_tag :notify_url, @transaction.notify_url, id: "citrusNotifyUrl"

      .col-md-8
        %h3.col-md-12.mtop20 Billing Address
        = fields_for @address do |af|
          .col-md-12.mtop20
            %label.col-md-3 First Name
            .col-md-5= af.text_field :first_name, class: "form-control", id: "citrusFirstName", required: true
          .col-md-12.mtop10
            %label.col-md-3 Last Name
            .col-md-5= af.text_field :last_name, class: "form-control", id: "citrusLastName", required: true
          .col-md-12.mtop10
            %label.col-md-3 Email
            .col-md-5= af.text_field :email, class: "form-control", id: "citrusEmail", required: true
          .col-md-12.mtop10
            %label.col-md-3 Mobile
            .col-md-5= af.text_field :mobile, class: "form-control", id: "citrusMobile", required: true
          .col-md-12.mtop10
            %label.col-md-3 Street 1
            .col-md-5= af.text_field :address1, class: "form-control", id: "citrusStreet1", required: true
          .col-md-12.mtop10
            %label.col-md-3 Street 2
            .col-md-5= af.text_field :address2, class: "form-control", id: "citrusStreet2", required: true
          .col-md-12.mtop10
            %label.col-md-3 Zipcode
            .col-md-5= af.text_field :zip, class: "form-control check_zip", id: "citrusZip", required: true
          .col-md-12.mtop10
            %label.col-md-3 City
            .col-md-5= af.text_field :city, class: "form-control city", id: "citrusCity", required: true
          .col-md-12.mtop10
            %label.col-md-3 State
            .col-md-5
              = af.select :state, india_states, {include_blank: 'Select State'}, class: "select_box state coco-select-box", id: "citrusState",  required: true
        .col-md-12
          #error.col-md-12.text-danger{style: "font-weight: bold; margin-left: 5px;"}
        .col-md-12.mtop20
          %ul.nav.nav-tabs
            %li.active
              %a{"data-toggle" => "tab", :href => "#credit_card"} Cards
            %li
              %a{"data-toggle" => "tab", :href => "#net_banking"} Net Banking
          .tab-content.ptop10
            #credit_card.tab-pane.fade.in.active
              .col-md-12.mtop10
                .col-md-12
                  %label.col-md-4 Card Type
                  .col-md-6
                    %select.coco-select-box#citrusCardType
                      %option{:selected => "selected", :value => "credit"} Credit
                      %option{:value => "debit"} Debit
                .col-md-12.mtop10
                  %label.col-md-4 Issuer Type
                  .col-md-6
                    %select.coco-select-box#citrusScheme
                      %option{:selected => "selected", :value => "VISA"} VISA
                      %option{:value => "mastercard"} MASTER
                .col-md-12.mtop10
                  %label.col-md-4 Card Number
                  .col-md-6
                    %input.form-control#citrusNumber{:type => "text", :value => ""}/
                .col-md-12.mtop10
                  %label.col-md-4 Card Holder Name
                  .col-md-6
                    %input.form-control#citrusCardHolder{:type => "text", :value => ""}/
                .col-md-12.mtop10
                  %label.col-md-4 Expiry date
                  .col-md-3
                    %input.form-control#citrusExpiry{:placeholder => "mm/yy", :type => "text", :value => ""}/
                  %label.col-md-2{style: "text-align: right;"} CVV/CVC
                  .col-md-3
                    %input.form-control#citrusCvv{:type => "text", :value => ""}/
              .col-md-12.text-center.mtop10.pbottom50
                %input.btn.btn-info.save-button.mtop20#citrusCardPayButton{:type => "button", :value => "Pay Now"}/
            #net_banking.tab-pane.fade
              .col-md-12.mtop10
                .col-md-6
                  %label Select Your Bank
                .col-md-6
                  %select.coco-select-box#citrusAvailableOptions
              .col-md-12.text-center.mtop10.pbottom50
                %input.btn.btn-info.save-button.mtop20#citrusNetbankingButton{:type => "button", :value => "Pay Now"}/


= content_for :extra_js do
  :javascript
    CitrusPay.Merchant.Config = {
          // Merchant details
          Merchant: {
              accessKey: 'HONXN1991PP1DDWG6CF2', //Replace with your access key
              vanityUrl: 'cocociti'  //Replace with your vanity URL
          }
      };

    fetchPaymentOptions();

    function handleCitrusPaymentOptions(citrusPaymentOptions) {
        if (citrusPaymentOptions.netBanking != null)
            for (i = 0; i < citrusPaymentOptions.netBanking.length; i++) {
                var obj = document.getElementById("citrusAvailableOptions");
                var option = document.createElement("option");
                option.text = citrusPaymentOptions.netBanking[i].bankName;
                option.value = citrusPaymentOptions.netBanking[i].issuerCode;
                obj.add(option);
            }
    }

      $('#citrusNetbankingButton').on("click", function () { makePayment("netbanking") });
      $("#citrusCardPayButton").on("click", function () { makePayment("card") });

    function citrusServerErrorMsg(errorResponse) {
        alert(errorResponse);
        console.log(errorResponse);
    }
    function citrusClientErrMsg(errorResponse) {
        alert(errorResponse);
        console.log(errorResponse);
    }
