.container
  .page-header
    .col-sm-5
      %h1
        Users
        %small= "#{@users.total_count} users"
    .col-sm-7.no-mar-pad.mtop25
      .pull-right
        ~ form_tag url_for, method: :get do
          .col-xs-11.no-mar-pad= text_field_tag :term, "", placeholder: "Search", class: "form-control", style: "width: 300px; border-radius: 4px 0px 0px 4px;"
          .col-xs-1.no-mar-pad
            %button.btn.btn-danger.pull-right{type: 'submit', style: "border-radius: 0px 4px 4px 0;"}
              %span.glyphicon.glyphicon-search
  .col-xs-12.no-mar-pad
    = paginate @users
    .table-responsive
      %table.table.table-striped.table-bordered.table-hover
        %thead
          %tr
            %th
            %th Name
            %th Email
            %th Phone
            %th Date of Joining
            %th Status
            %th Role
            %th Edit Role
            %th Verify
            %th Ban

        %tbody
          - @users.each_with_index do |user, i|
            %tr{id: "user-row-#{user.id}"}
              %td
                - page = params[:page].blank? ? 1 : params[:page].to_i
                = (i+1) + 40*(page-1)
              = render partial: "user", locals: {user: user, i: i}

    = paginate @users

= content_for :extra_js do
  :javascript
    $(document).ready(function(){
      $(".edit-user").click(function(){
        $(".errors").html("");
        $(this).closest("form").attr("action", "/admin/users/" + $(this).data("id"));
        $("#edit-user input[name*=email]").val($(this).data("email"));
        $("#edit-user select[name*=role]").val($(this).data("role"));
      });

    });
