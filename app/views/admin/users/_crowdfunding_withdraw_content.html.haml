- withdraws.each_with_index do |withdraw, i|
  %tr
    %td
      - page = page.blank? ? 1 : page.to_i
      = (i+1) + 30*(page-1)
    %td
      = link_to myprofile_path(withdraw.user.slug), target: "_blank" do
        = withdraw.user.name
    %td
      = link_to showcase_path(withdraw.showcase), target: "_blank" do
        = withdraw.showcase.title
    %td= withdraw.showcase.goal_amount
    %td= withdraw.coins
    %td= withdraw.name
    %td= withdraw.acc_no
    %td= withdraw.ifsccode
    %td= withdraw.user.phone
    %td= withdraw.mmid
    %td= withdraw.created_at.strftime("%d %b, %Y %H:%M")
    %td
      - unless withdraw.deactivated?
        = select_tag :status, options_for_select(Withdraw::STATUS_NAME, withdraw.status), class: "withdraw-status-#{withdraw.id}"
      - else
        = withdraw.status_name
    %td
      = text_area_tag :comment, withdraw.comment, rows: 2, class: "withdraw-comment-#{withdraw.id}"
    %td.text-center
      %span.pon.withdraw-edit{"data-id" => "#{withdraw.id}"}
        .fa.fa-pencil
