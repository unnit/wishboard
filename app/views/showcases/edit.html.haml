.container.mtop50.ptop20.pbottom70
  .col-xs-12.col-sm-6.col-sm-offset-3.light-border.bg-white.bg-shad.pad-v-20
    = form_for @showcase do |f|
      .col-xs-12.col-sm-12.text-center-mob.mbottom30{style: "overflow: hidden;max-height:400px;"}
        .preview
          = cl_image_tag @showcase.image, class: "img-responsive inline-display", width: 637, crop: :fill, gravity: :face
        .glyphicon.glyphicon-remove.preview-delete.bg-white{style: "position: absolute;z-index: 1;"}
        .glyphicon.glyphicon-camera.file-input-button{style: "display:none;font-size: 65px;color: #E0E0E0;padding: 20px;border: 1px dashed;"}
          = cl_image_upload_tag(:image)
        .progress.progress-striped{style: "display: none;height: 10px;width:107px;"}
          .progress-bar{style: "width: 0%;"}
      .col-xs-12.col-sm-12.text-center
        = f.text_field :title, placeholder: "Title", class: "form-control coco-input-field hvr-underline-from-left", required: true, maxlength: 100
      .col-xs-12.col-sm-12.text-center.ptop10
        = f.text_area :description, placeholder: "Description", class: "form-control coco-input-field hvr-underline-from-left", required: true, maxlength: 1000
      .col-xs-4.col-sm-3.ptop10
        = f.text_field :year, placeholder: "Year", class: "form-control coco-input-field hvr-underline-from-left", required: true, maxlength: 4
      .col-xs-8.col-sm-6.ptop10
        = f.fields_for :location do |lf|
          = lf.text_field :name, placeholder: "Location", class: "form-control coco-input-field hvr-underline-from-left", required: true, maxlength: 100
      .col-xs-12.col-sm-3.no-mar-pad.mtop10{style: "color: #9A9A9A;"}
        %span.no-mar-pad.pull-left
          = f.radio_button :showcase_type, "#{Showcase::SHOWCASE_VALUES[0]}", required: true
          %label.mbottom0 Showpiece
        %span.no-mar-pad.pull-left
          = f.radio_button :showcase_type, "#{Showcase::SHOWCASE_VALUES[1]}", required: true
          %label.mbottom0 Wish
      .col-xs-12.col-sm-12.mtop10.text-center.showcase-btn-wrapper{style: "padding-top: 34px;"}
        = f.submit "Showcase", class: "btn btn-primary btn-shadow btn-social weight-bold showcase-submit", style: "display: none;"
