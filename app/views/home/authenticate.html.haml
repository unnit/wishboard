.container-fluid.ptop50.padding0.bg-auth
  .col-xs-12.col-sm-6{style: "padding-top: 8%;"}
    %ul.nav.nav-tabs{style: "border-bottom: none;margin-left: 40%;"}
      %li.active
        %a{"data-toggle" => "tab", :href => "#home-login", style: "border: none;padding: 12px 15px;border-radius: 0px;color: white;"} Login
      %li.toggle-url
        %a{"data-toggle" => "tab", :href => "#home-sign-up", style: "border: none;padding: 12px 15px;border-radius: 0px;color: white;"} Sign Up
    .tab-content.ptop10{style: "min-height: 600px;"}
      #home-login.tab-pane.fade.in.active
        .col-md-12.mtop40
          = form_for(User.new, :url => new_user_session_path, remote: true, html: {"data-parsley-validate" => true}) do |f|
            .col-sm-12.errors
            .form-group.clearfix
              = f.label :email, :class => 'col-sm-3 control-label text-right'
              .col-sm-7
                .input-group
                  %span.input-group-addon
                    %i.fa.fa-user
                  = f.text_field :email, :autofocus => true, placeholder: t("email_address", default: "Email Address"), class: "form-control", "data-parsley-trigger" => "change", required: true
            .form-group.clearfix
              = f.label :Password, :class => 'col-sm-3 control-label text-right'
              .col-sm-7
                .input-group
                  %span.input-group-addon
                    %i.fa.fa-lock
                  = f.password_field :password, :placeholder => t('password', default: "Password"), class: "form-control", "data-parsley-trigger" => "change", required: true
            .form-group.clearfix.mtop20
              .col-sm-offset-4.col-sm-6
                = link_to "Forgot password?", new_user_password_path, class: "white-fg"
            .form-group.clearfix.mbottom40.pbottom100
              .col-sm-4.col-sm-offset-4.text-center.mbottom40
                = f.submit "Login",:class => 'btn btn-primary pop-up-but login-button'
      #home-sign-up.tab-pane.fade
        .col-md-12.mtop40
          = form_for(User.new, :url => user_registration_path, remote: true, html: {"data-parsley-validate" => true, class: "agreement-require"}) do |f|
            .col-sm-12.errors
            .form-group.clearfix
              = f.label :email, :class => 'col-sm-3 control-label text-right'
              .col-sm-7
                .input-group
                  %span.input-group-addon
                    %i.fa.fa-user
                  = f.text_field :email, :autofocus => true, placeholder: t("email_address", default: "Email Address"), class: "form-control", "data-parsley-trigger" => "change", required: true
            .form-group.clearfix
              = f.label :Password, :class => 'col-sm-3 control-label text-right'
              .col-sm-7
                .input-group
                  %span.input-group-addon
                    %i.fa.fa-lock
                  = f.password_field :password, :placeholder => t('password', default: "Password"), class: "form-control", "data-parsley-trigger" => "change", required: true
            .form-group.clearfix
              = f.label :password_confirmation, "Confirm Password", :class => 'col-sm-3 control-label text-right'
              .col-sm-7
                .input-group
                  %span.input-group-addon
                    %i.fa.fa-lock
                  = f.password_field :password_confirmation, :placeholder => t('password', default: "Password"), class: "form-control", "data-parsley-trigger" => "change", required: true
            .form-group.clearfix
              .col-sm-8.col-sm-offset-2
                %span.mleft10.textt-center By continuing, you agree to the Terms of Service
            .form-group.clearfix.mbottom40.pbottom100
              #submit-signup.pulse-loader{style: "display:none;"} Loading...
              .col-sm-4.col-sm-offset-4.mbottom40
                = f.submit "Sign up", :class => 'btn btn-primary pop-up-but'
  .col-xs-12.col-sm-6.padding20
    %h3.grey-fg.text-center.font21{style: "margin-top: 29.5%;"}
      Discover things near you as and when you need it.
    =link_to rent_path do
      .col-xs-4.col-sm-4.col-xs-offset-4.col-sm-offset-4.btn-social.padding20.font25.text-center.white-fg.mtop20 Rent
