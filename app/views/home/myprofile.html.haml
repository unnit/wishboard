= content_for :title do
  - title = "#{@user.name} (@#{@profile.slug}) | Cocociti"
= content_for :meta_content do
  - if @profile.about.present?
    = content_for :meta_content do
      - meta_content = "#{@profile.about}"
  - else
    = content_for :meta_content do
      - meta_content = "Discover wishes and achievements of #{@user.name}"
.container-fluid.ptop50.mob-ptop100.pbottom50.padding0.helvetica-font.bg-light-grey.min-height1000
  = render partial: "profile", locals: {user: @user}
  .container.padding0
    .col-md-12.mbottom10
      .ol.breadcrumb.no-mar-pad.note-font-size
        = render_breadcrumbs tag: :li, separator: "&nbsp;&nbsp;<span class='glyphicon glyphicon-menu-right extra-small-font'></span>&nbsp;&nbsp;".html_safe
    .col-md-12.no-mar-pad.mbottom20.hidden-xs
      - @showcases.each do |showcase|
        .col-sm-2
          .col-sm-12.padding5.bg-white.text-right
            %span.font11.grey-fg.full-width.pull-left
              .fa.fa-clock-o
              = time_ago_in_words(showcase.achieved_at)
            = link_to showcase_path(showcase), remote: true do
              - if showcase.image.present?
                = cl_image_tag showcase.image, class: "img-responsive inline-display", width: 300, height: 225, crop: :fill, gravity: :face, alt: showcase.title
              - else
                .white-bg.cc-dark-fg.font12.inline-block.text-center.ptop30.full-width{style: "height: 116px;"}
                  - if showcase.custom_wish_type?
                    = showcase.title.humanize
                  - else
                    %span
                      - if showcase.showpiece?
                        = showcase.fulfilled_wish_prefix_label.lstrip.humanize
                      - else
                        = showcase.future_wish_prefix_label.lstrip.humanize
                    %span{style: "word-break: break-word;"}
                      = showcase.title
            %h6.mbottom0.mtop5=truncate showcase.title, length: 22
    .col-xs-12.no-mar-pad.visible-xs.mbottom20
      #myCarousel.carousel.slide{data: {ride: "carousel"}}
        .carousel-inner{role: "listbox"}
          - @showcases.each_slice(2).with_index do |showcases, i|
            .item{class: "#{'active' if i==0}"}
              - showcases.each do |showcase|
                .col-xs-6
                  .col-xs-12.padding5.bg-white.text-center
                    %span.font11.grey-fg.full-width.text-right.pull-left
                      .fa.fa-clock-o
                      = time_ago_in_words(showcase.achieved_at)
                    = link_to showcase_path(showcase), remote: true do
                      - if showcase.image.present?
                        = cl_image_tag showcase.image, class: "img-responsive inline-display", width: 300, height: 225, crop: :fill, gravity: :face, alt: showcase.title
                      - else
                        .white-bg.cc-dark-fg.font12.inline-block.text-center.ptop30.full-width{style: "height: 116px;"}
                          - if showcase.custom_wish_type?
                            = showcase.title.humanize
                          - else
                            %span
                              - if showcase.showpiece?
                                = showcase.fulfilled_wish_prefix_label.lstrip.humanize
                              - else
                                = showcase.future_wish_prefix_label.lstrip.humanize
                            %span{style: "word-break: break-word;"}
                              = showcase.title
                    %h6.mbottom0.mtop5=truncate showcase.title, length: 22
    - if current_user && current_user.same_user?(@user)
      .col-xs-12.col-sm-3.mbottom20
        = render partial: "showcases/create_collection"
    .col-xs-12.col-sm-3.mbottom20
      = link_to myshowpieces_path(@profile.slug), style: "color: #292929", class: "j-loader-trigger-link" do
        .col-xs-12.col-sm-12.folder-prof.text-center.hvr-float
          %span.scase-name-wrap.white-fg.font-medium
            Fulfilled
            .badge.weight500=  (@user == current_user)? @user.showcases.showpieces.count : @user.showcases.public_accessible.active.showpieces.count
    .col-xs-12.col-sm-3.mbottom20
      = link_to mywishes_path(@profile.slug), style: "color: #292929", class: "j-loader-trigger-link" do
        .col-xs-12.col-sm-12.folder-prof.text-center.hvr-float
          %span.scase-name-wrap.white-fg.font-medium
            Future
            .badge.weight500= (@user == current_user)? @user.showcases.wishes.count : @user.showcases.public_accessible.active.wishes.count
    .col-xs-12.col-sm-3.mbottom20
      = link_to mymomentary_path(@profile.slug), style: "color: #292929", class: "j-loader-trigger-link" do
        .col-xs-12.col-sm-12.folder-prof.text-center.hvr-float
          %span.scase-name-wrap.white-fg.font-medium
            Momentary
            .badge.weight500= (@user == current_user) ? @user.showcases.momentary.count : @user.showcases.public_accessible.active.momentary.count
    .collection-strip
      - @user.collections.each do |collection|
        = render partial: "showcases/collection", locals: {collection: collection}
