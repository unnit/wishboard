%nav.navbar.navbar-default.navbar-fixed-top.topnav.violet-bg.no-border.bg-shad{:role => "navigation", style: "border-radius: 0px;"}
  .navbar.navbar-fixed-top
    .container
      .navbar-header
        %button.navbar-toggle{data: {toggle: "collapse", target: ".navbar-collapse"}}
          %span.icon-bar
          %span.icon-bar
          %span.icon-bar
        %a.navbar-brand.pleft5.white-fg{href: "/", style: "font-size: 1.6em;letter-spacing: 1px;"}
          Cocociti
        = yield :header_extra
      .col-xs-12.col-sm-4.no-mar-pad.hidden-xs.search-wrap{style: "margin-top: 8px;"}
        ~ form_tag results_path, method: :get, id: "header-search" do
          .col-xs-12.col-sm-11.no-mar-pad= text_field_tag :query, params[:query], placeholder: "Search", class: "form-control search-query cc-med-bg cc-dark-fg-border", style: "border-radius: 20px;"
          .col-xs-1.col-sm-1.no-mar-pad{style: "margin-left: -41px;"}
            %button.btn{type: 'submit', style: "background-color: transparent;"}
              %span.glyphicon.glyphicon-search.white-fg
      .navbar-collapse.collapse.nav-border
        %ul.nav.navbar-nav.navbar-right.mtop0
          - if current_user
            %li.hidden-xs
              .fa.fa-bell-o.font20.pon.pull-right.mtop15.notif-icon.white-fg
              - if current_user.unchecked_notififcations_count > 0
                .badge.notif-badge.pon.pull-right.mtop5.notif-icon.bg-white.cc-dark-fg= current_user.unchecked_notififcations_count
              .sq-rot.notif-toggle
              .notif-arrow.notif-toggle
              .notif-wrap.bx-shad.notif-toggle.helvetica-font
                .col-xs-12.col-sm-12.text-center.notif-loader.padding10
                  %i.fa.fa-circle-o-notch.fa-spin.font21
                  Please wait...
                .col-xs-12.col-sm-12.notif-content.no-mar-pad
                = link_to notifications_path do
                  .col-xs-12.col-sm-12.padding5.text-center.bg-light-grey.weight600
                    See All
            %li.hidden-xs
              %ul.pro-view.pleft-10
                %li.dropdown.pull-left
                  = link_to "#", class: "dropdown-toggle", data: {toggle: "dropdown"} do
                    %span.avatar.pull-right.mleft5{style: "margin-top: -7px;margin-right: 15px;"}
                      = cl_image_tag current_user.avatar, class: "img-circle pull-right mleft5", width: 30, height: 30, crop: :fill
                  %ul.dropdown-menu.pull-left.mtop10.font13.bg-shad{style: "width:180px;"}
                    .arrow-wrapper-nav
                      .arrow-nav
                      .arrow-z-nav
                    %li
                      = link_to myprofile_path(current_user.profile.slug), style: "white-space: normal;" do
                        %span.black-fg= truncate current_user.name, length: 25
                        %br
                        %span.font11.grey-fg View Profile
                    %li.divider{style: "overflow: visible"}
                    %li
                      = link_to settings_path, style: "white-space: normal;" do
                        %span.grey-fg Settings
                    %li.divider{style: "overflow: visible"}
                    %li
                      = link_to invitations_path, style: "white-space: normal;" do
                        %span.grey-fg Invite friends
                    %li.divider{style: "overflow: visible"}
                    %li
                      = link_to wallet_path, style: "white-space: normal;" do
                        %span.grey-fg Wallet
                    %li.divider{style: "overflow: visible"}
                    %li
                      = link_to destroy_user_session_path, method: :delete, style: "white-space: normal;" do
                        %span.grey-fg Sign Out
            %li.hidden-xs= link_to "Wish", "#", class: "btn white-fg ps-nav-btn cc-med-bg", style: "padding: 7px 12px;margin-top:7px;border-radius:18px;display: #{@sh_btn || 'block;'}"
            %li.visible-xs.bg-white
              = link_to myprofile_path(current_user.profile.slug), style: "white-space: normal;" do
                %span.black-fg= truncate current_user.name, length: 25
                %br
                %span.font11.grey-fg View Profile
            %li.visible-xs.bg-white
              = link_to settings_path, style: "white-space: normal;" do
                %span.grey-fg Settings
            %li.visible-xs.bg-white
              = link_to invitations_path, style: "white-space: normal;" do
                %span.grey-fg Invite friends
            %li.visible-xs.bg-white
              = link_to wallet_path, style: "white-space: normal;" do
                %span.grey-fg Wallet
            %li.visible-xs.bg-white.border-bt-side
              = link_to destroy_user_session_path, method: :delete, style: "white-space: normal;" do
                %span.grey-fg Sign Out
          - else
            %li.hidden-xs
              = link_to "SignUp", authenticate_path(tab: "signup"), class: "btn", style: "padding: 7px 15px;margin-top: 7px;border-radius:18px;border: 1px solid #ccc;"
            %li.hidden-xs
              = link_to "Login", authenticate_path, class: "btn cc-dark-bg white-fg mleft10", style: "padding: 7px 15px;margin-top: 7px;border-radius:18px;"
            %li.visible-xs.bg-white
              = link_to authenticate_path, style: "white-space: normal;" do
                %span.grey-fg Login
              = link_to authenticate_path(tab: "signup"), style: "white-space: normal;" do
                %span.grey-fg SignUp
  .full-width.visible-xs.cc-dark-bg.font20.pos-fixed.text-center{style: "top: 50px;"}
    - if current_user
      = link_to root_path do
        .col-xs-3.padding10.feed-mob
          .fa.fa-newspaper-o.white-fg
      = link_to notifications_path do
        .col-xs-3.padding10.notif-mob
          .fa.fa-bell-o.white-fg
          - if current_user.unchecked_notififcations_count > 0
            .badge.notif-badge.pon.mright0.neg-mleft15.notif-icon.bg-white.cc-dark-fg= current_user.unchecked_notififcations_count
      .col-xs-3.padding10.follow-mob
        = link_to root_path(view: "follow") do
          .fa.fa-group.white-fg
      .col-xs-3.padding10.search-mob
        .fa.fa-search.white-fg
    - else
      .col-xs-6.padding10
        = link_to authenticate_path(tab: "signup") do
          .btn.btn-sm.bg-white.cc-dark-fg.full-width Join
      .col-xs-6.padding10
        = link_to authenticate_path do
          .btn.btn-sm.full-width.white-fg.light-border Login
#showcase-modal.modal.fade.padding0
  %span.pull-right.padding5.mbottom20.white-fg.weight600.font25.pon.ps-close-wrapper{ style: "z-index: 1051;", "data-dismiss" => "modal"} x
  .modal-dialog
    - if current_user && !@scase_modal.present?
      = render partial: "home/post_showcase", locals: {showcase: @scase}
#cont-wrapper.modal.fade.padding0.ptop20
.messages
