.col-md-12.rev-bar
  .col-md-2
    = image_tag review.user.avatar, size: "70x70", class: "img-circle"
  .col-md-10
    %h4.rev-name= review.user.name
    %i.pull-right.star-mar{class: "rated-#{review.user.id}"}
      = render partial: 'rated', locals: {rate: review.user.rated_value(@product)}
    %P.rev-p= review.comment