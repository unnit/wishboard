.col-xs-12.col-sm-12.padding0
  = hidden_field_tag :cocotransfer_id, value: cocotransfer.id
  = form_for cocotransfer, remote: remote, html:{id: "cocotranfer_form"} do |f|
    = f.hidden_field :transferable_id, value: cocotransfer.transferable_id
    = f.hidden_field :transferable_type, value: cocotransfer.transferable_type
    = f.hidden_field :wallet_amount, value: cocotransfer.wallet_amount
    = f.hidden_field :amount, value: cocotransfer.amount
    = f.hidden_field :available_wallet_amount, value: current_user.try(:total_profile_withdraw_available_amount).to_i

    = cocotransfer.wallet_amount + cocotransfer.amount
    / = f.hidden_field :wallet_amount, value: cocotransfer.wallet_amount
    .col-xs-12.col-sm-12.mbottom20.padding0
      .col-xs-12.col-sm-3.pleft0
        %span Amount
        %i.fa.fa-inr
      .col-xs-12.col-sm-9.padding0
        = f.text_field :total_amount, placeholder: "Gift amount", class: "form-control bg-white"
    .col-xs-12.col-sm-12.mbottom20.padding0
      .col-xs-12.col-sm-3.pleft0
        %span Use Wallet Amount
      .col-xs-12.col-sm-9.padding0.font10.pleft0
        = f.check_box :use_wallet_amount, checked: true
        %i.fa.fa-inr
        %span#cocotransfer_wallet_amount_display
          #{cocotransfer.wallet_amount} 
    .col-xs-12.col-sm-12.mbottom20.padding0
      .col-xs-12.col-sm-3.pleft0
        %span Payble Amount
      .col-xs-12.col-sm-9.padding0.font10.pleft0
        %i.fa.fa-inr 
        %span#cocotransfer_amount_display
          #{@cocotransfer.amount} 

    .col-xs-12.col-sm-12.mbottom20.padding0
      .col-xs-12.col-sm-3.pleft0
        %span Email
        %i.fa.fa-envelope-o
      .col-xs-12.col-sm-9.padding0
        = f.email_field :email, placeholder: "Email", class: "form-control bg-white"
    .col-xs-12.col-sm-12.padding0
      .col-xs-12.col-sm-3.pleft0
        %span Contributer's Name
        %i.fa.fa-user
      .col-xs-12.col-sm-9.padding0
        = f.text_field :donor_name, placeholder: "Contributer's Name", class: "form-control bg-white"
    .col-xs-12.col-sm-12.mbottom20.padding0
      .col-md-offset-3.col-xs-12.col-md-9.font10.pleft0
        = f.check_box :hide_identity
        %i.fa.fa-eye-slash
        %span.extra-small-font Stay anonymous
    .col-xs-12.col-sm-12.mbottom20.padding0
      .col-xs-12.col-md-3.pleft0
        %span Mobile
        %i.fa.fa-mobile
      .col-xs-4.col-sm-3.padding0
        = select("cocotransfer", "phonecode", Country.all.collect {|c| [ "+" + c.phonecode+ "  ("+c.iso+")", c.phonecode ] },{:selected => current_user.try(:profile).try(:phonecode), include_blank: false}, {class: "form-control user-phone-prefix"})
      .col-xs-8.col-sm-6.pright0
        = f.text_field :phone, :placeholder => "Mobile No", class: "form-control user-mobile-no", maxlength: 10
    .col-xs-12.col-sm-12.text-center
      = f.submit "#{submit_name}", class: "btn btn-md cc-dark-bg white-fg weight-bold"
