%span.button-checkbox
  .btn-group
    %button.btn.btn-default.dropdown-toggle{type: "button", data: {color: "primary", toggle: "dropdown"}}
      %span.selection.cat-text.img-text-pad= @selected.blank? ? "Select Sub-catgories" : @selected
      %span.caret
    %ul.dropdown-menu.cat-text{role: "menu"}
      %li= link_to "Select Sub-catgories", "javascript:;", data: {id: nil, name: "Select Sub-catgories"}, class: "cat-sub"
      - subs.each do |cat|
        %li= link_to cat.name, "javascript:;", data: {id: cat.id, name: cat.name}, class: "cat-sub"