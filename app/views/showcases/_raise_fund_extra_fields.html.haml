= form_for @showcase, html: { class: "update-raise-showcase" } do |f|
  .col-xs-12.col-sm-6.no-mar-pad.text-center.photo-wrapper.hidden-overflow{style: "height: 200px;"}
    .preview{"data-source": "showcase"}
    .preview-delete-fullfill.bg-white.pon.pos-absolute.font16.hide-display x
    .col-xs-12.col-sm-12.no-mar-pad
      .glyphicon.glyphicon-camera.file-input-button.mtop40.padding20.cc-dark-fg.dotted-border{style: "font-size: 65px;display: inline-block;"}
        = cl_image_upload_tag(:image, html: {class: "cloudinary-fileupload-raise-edit file-upload-trigger", "data-height": "100", "data-width": "100"})
    .col-xs-12.col-sm-12.no-mar-pad
      .progress.progress-striped.progress-edit.mbottom0{style: "display: none;height: 6px;width:107px;"}
        .progress-bar.progress-bar{style: "width: 0%;"}
  .col-xs-12.col-sm-6.text-center.ptop10{style: "height: 200px;"}
    ~ f.text_area :description, placeholder: "Tell the story behind this wish?", class: "form-control coco-input-field", maxlength: 2500, style: "height: 189px;"
  .col-xs-12.col-sm-6.ptop20.pbottom10
    = f.text_field :all_tags, placeholder: "Tags (Use enter, comma or tab to separate)", class: "tm-input form-control tm-input-inverse tm-input-typeahead coco-input-field"
  .col-xs-12.col-sm-6.ptop20
    = f.fields_for :location do |lf|
      = lf.text_field :name, placeholder: "Where", class: "form-control coco-input-field pac-input", maxlength: 100
  .col-xs-12.col-sm-12.ptop20
    = f.text_field :video_link, placeholder: "Video Link", class: "form-control coco-input-field pac-input", maxlength: 100
  .col-xs-12.col-sm-12.mtop20.mbottom20.text-center
    = f.submit "Update", class: "btn cc-dark-bg white-fg weight-bold showcase-raise-update-submit"
= content_for :extra_js do
  :javascript
    $(document).ready(function(){
      var places_input_1= $('.pac-input')[1];
      google.maps.event.addDomListener(window, 'load', function () {
          var autocomplete = new google.maps.places.Autocomplete(places_input_1);
          google.maps.event.addDomListener(places_input_1, 'keydown', function(e) {
            if (e.keyCode == 13 && $('.pac-container:visible').length) {
              e.preventDefault();
            }
          });
      });
    })
