.col-xs-12.col-sm-12.no-mar-pad
  .col-xs-12.col-sm-12.no-mar-pad{style: "height: 198px;"}
    ~ f.text_area :backstory_description, placeholder: "Tell the story of fullfillment of this wish?", class: "form-control coco-plain-input-field pleft5 transition-effect", maxlength: 2500, rows: 1, style: "height: 198px;"
  .col-xs-12.col-sm-12.no-mar-pad.photo-wrapper.ptop10{class: "#{@showcase.backstory_image.present? ? '' : 'hide-display'}", style: "height: 164px;"}
    .preview
      - if @showcase.backstory_image.present?
        = cl_image_tag @showcase.backstory_image, class: "img-responsive inline-display", height: 150, crop: :fill, gravity: :face, alt: @showcase.title
    .preview-delete-fullfill.bg-white.pon.pos-absolute.font16{class: "#{@showcase.backstory_image.blank? ? 'hide-display' : 'block-display'}", style: "left: 0;top:10px;"} x
    .col-xs-12.col-sm-12.no-mar-pad.min-height0
      .glyphicon.glyphicon-camera.file-input-button.mtop20.padding20.cc-dark-fg.dotted-border{style: "font-size: 65px;display: #{@showcase.backstory_image.present? ? 'none': 'inline-block'};"}
        = cl_image_upload_tag(:backstory_image, html: { class: "cloudinary-fileupload-fullfill file-upload-trigger", "data-height": "150", "data-width": "100", "data-height-non-source": "150"  })
    .col-xs-12.col-sm-12.no-mar-pad.min-height0
      .progress.progress-striped.progress.mbottom0{style: "display: none;height: 6px;width:107px;"}
        .progress-bar.progress-bar{style: "width: 0%;"}
  .col-xs-12.col-sm-12.no-mar-pad.cc-dark-fg.font16.ptop10
    .col-xs-3.col-sm-4.no-mar-pad
      %span.pon.file-input-button.pull-left.inline-block.pos-relative
        %i.fa.fa-file-image-o.font21
        = cl_image_upload_tag(:backstory_image, html: { class: "cloudinary-fileupload-fullfill file-upload-trigger", "data-height": "150", "data-width": "100", "data-height-non-source": "150"  })
    .col-xs-9.col-sm-8.text-right.pull-right.fs-btn-wrapper.no-mar-pad
      .white-fg.no-mar-pad.loader-out-showcase-fullfill-button.inline-block
        = f.submit " Add Backstory", class: "loader-button loader-in-showcase-fullfill-button showcase-backstory-submit"
        .loader-effect.loader-in-showcase-fullfill-button.text-center{:style => "display:none;padding-top: 4px;"}
          .ball-clip-rotate
            %div
