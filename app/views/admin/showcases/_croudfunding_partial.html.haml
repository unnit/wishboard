- showcases.each_with_index do |showcase, i|
  %tr
    %td
      - page = page.blank? ? 1 : page.to_i
      = (i+1) + 30*(page-1)
    %td
      = link_to edit_admin_showcase_path(showcase), target: "_blank" do
        %span= truncate showcase.title, length: 35
    %td= showcase.admin_status_name
    %td= showcase.created_at.strftime("%d %b, %Y %H:%M")
    %td= showcase.goal_amount
    %td= showcase.raised_amount
    %td= link_to showcase.cocotransfers.complete.count, "#cocotransfers-#{showcase.id}", data: {toggle: "modal" }
    = render partial: "cocotransfers", locals: {showcase: showcase}
    = render partial: "contributer_profiles", locals: {showcase: showcase}
    %td= link_to showcase.user.name, "#profile-#{showcase.user.profile_id}", data: {toggle: "modal" }
    = render partial: "admin/users/profile", locals: {profile: showcase.user.profile}

    %td
      = link_to admin_showcase_path(showcase), method: :delete, method: :delete, data: { confirm: "Are you sure you want to delete?" } do
        Delete
:css
  .modal.cocotransfers-modal{
   z-index: 1049;
  }
