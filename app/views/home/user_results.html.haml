.container-fluid.ptop50.mob-ptop100.bg-shad.pbottom50.padding0.helvetica-font.bg-light-grey{style: "min-height:1000px;"}
  .container.padding0.mtop30
    .col-xs-12.col-sm-12.padding10.ptop0.user-wrapper
      - unless @users.blank?
        = render partial: "user_card", locals: {users: @users, min_width: "282px"}
      - else
        %h3.text-center Sorry, No results found.
    #infinite-scrolling-content.hidden
      = paginate @users, param_name: "users"
    .col-xs-12.col-sm-12.text-center.feed-loader.padding40{style: "display:none;"}
      %i.fa.fa-circle-o-notch.fa-spin.font21
      Please wait...
