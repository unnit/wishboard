.container-fluid.mtop50.bg-shad.pbottom50.padding0.helvetica-font.bg-light-grey{style: "min-height:1000px;"}
  = render partial: "profile", locals: {user: @user}
  .container.padding0
    .col-md-12.mbottom10
      .ol.breadcrumb.no-mar-pad.note-font-size
        = render_breadcrumbs tag: :li, separator: "&nbsp;&nbsp;<span class='glyphicon glyphicon-menu-right extra-small-font'></span>&nbsp;&nbsp;".html_safe
    .col-xs-12.col-sm-12.wiki-strip.mbottom20
      - @user.wikis.each do |wiki|
        = render partial: "home/wiki", locals: { wiki: wiki }
    - if current_user == @user
      .col-xs-12.col-sm-12
        - if current_user.wikis.count < 3
          - (3 - @user.wikis.count).times do |x|
            .col-xs-12.col-sm-12.mbottom20.no-mar-pad{class: "new-wiki-#{x+1}"}
              = render partial: "home/create_wiki"
        - else
          .col-xs-12.col-sm-12.mbottom20.no-mar-pad.new-wiki-1
            = render partial: "home/create_wiki"
