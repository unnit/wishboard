.media.padding5.mtop0.comment-wrap{id: "media-comment-#{comment.id}"}
  .media-left
    = link_to myprofile_path(comment.user.profile.slug) do
      = cl_image_tag comment.user.avatar, class: "img-circle media-object", width: 30, height: 30, crop: :fill, gravity: :face
  .media-body.font-medium
    - if comment.owner?(current_user)
      %i.glyphicon.glyphicon-edit.grey-fg.action-showcase.grey-fg.pull-right.mtop5.mleft5.pon
      .col-xs-4.col-sm-2.option-showcase.bg-shad.bg-white.pull-right.text-center
        %span.full-width.grey-fg.pull-left.small.padding5.edit-comment-showcase.pon
          Edit...
        = link_to delete_comment_showcase_path(comment), method: :delete, data: { confirm: "Are you sure you want to delete this comment?" }, remote: true, class: "full-width grey-fg pull-left small padding5" do
          Delete...
    = link_to myprofile_path(comment.user.profile.slug) do
      %span.grey-fg= comment.user.name.titleize
    %span.pull-right.font11.mtop5.grey-fg
      .fa.fa-clock-o
      = time_ago_in_words(comment.created_at)
    .view-comment-showcase{class: "view-comment-#{comment.id}"}
      %span.small.grey-fg.excerpt-comment-desc= simple_format(truncate_html(comment.description.gsub("\r\n", "<br>"), 150))
      - if comment.description.length > 150
        %span.small.grey-fg.full-comment-desc{style: "display: none;"}= simple_format(comment.description.gsub("\r\n", "<br>"))
        %a.small.grey-fg.see-more-comment.pon{style: "color: blue !important;"} See More
    - if comment.owner?(current_user)
      = form_for comment, url: edit_comment_showcase_path(comment), remote: true, method: :post, html: {class: "form-comment-showcase form-comment-#{comment.id}"} do |f|
        = f.text_area :description, rows: 3, class: "form-control comment-description"
        = f.submit "Update", class: "btn btn-primary btn-social mtop10 btn-shadow"
