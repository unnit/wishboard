.col-xs-12.col-sm-12.padding10.font-bit-large.bg-shad.cc-dark-bg.white-fg
  .media
    .media-left.media-middle
      %i.fa.fa-bullhorn.font25
    .media-body
      You are gifting&nbsp;
      %i.fa.fa-inr
      %span.inline-block.weight600{class: "cocotransfer_display_amount"}
        #{cocotransfer.total_amount}
      -if cocotransfer.profile_transfer?
        to #{cocotransfer.receiver.name}
      -elsif cocotransfer.showcase_transfer?
        to #{cocotransfer.receiver.name} for #{cocotransfer.showcase_title}
