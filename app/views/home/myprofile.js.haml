$('.feed-loader').hide();
$(".showcase-strip").append("#{j render partial: "showcases", locals: {showcases: @showcases}}")
-if @showcases.next_page
  $('#infinite-scrolling-content .pagination').replaceWith("#{j paginate @showcases, param_name: 'showcases'}");
- else
  $(window).off('scroll');
  $('#infinite-scrolling-content .pagination').remove();
