.col-xs-12.col-sm-12.no-mar-pad.create-coll-wrapper{style: "border-radius: 2px;border: 1px solid #5A5A5A;height: 198px"}
  .col-xs-12.col-sm-12.no-mar-pad.text-center.full-height
    .plus-sprite.pon.plus-prof
    %h5.mtop5.pon.grey-fg.plus-prof Add
    = form_tag create_collection_showcases_path, remote: true, class: "form-horizontal create-collect col-xs-10 col-xs-offset-1 col-sm-10 col-sm-offset-1 hide-display" do
      .close-sprite.pon.clos-c-collect.pos-absolute{style: "left: -10px;opacity: 0.5;top: 10px;"}
      .form-group{style: "margin-top: 35.5px;"}
        %label Name
        = text_field_tag :name, params[:name], class: "form-control grey-bg cc-field", required: true, maxlength: 100
      .form-group
        = submit_tag "Create", class: "btn btn-sm black80-bg white-fg"
      .form-group
        .create-collect-err{style: "color: red;"}
