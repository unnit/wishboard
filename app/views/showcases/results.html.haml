.container-fluid.ptop50.mob-ptop100.pattern-bg{style: "min-height: 700px;"}
  .container.mtop40
    .col-xs-12.col-sm-6.col-sm-offset-3
      .col-xs-12.col-sm-12.no-mar-pad.showcase-strip.mbottom40
        - unless @showcases.blank?
          = render partial: "home/showcases", locals: {showcases: @showcases}
        - else
          %h3.mtop40.text-center
            Ayyo!
            %br
          %h4.grey-fg.text-center{style: "word-break: break-all;"} No results found for #{params[:query]}
      #infinite-scrolling-content.hidden
        = paginate @showcases, param_name: "showcases"
      .col-xs-12.col-sm-12.text-center.feed-loader.padding40{style: "display:none;"}
        %i.fa.fa-circle-o-notch.fa-spin.font21
        Please wait...
