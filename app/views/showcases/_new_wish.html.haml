.container.mtop30.padding15.bg-white{style: "max-width:637px;"}
  = form_for showcase, url: url, html: {class: "create-showcase"}, remote: true do |f|
    = hidden_field_tag :category_id
    .col-xs-12.col-sm-12.text-center.padding20.photo-wrapper
      .preview
      .preview-delete-fullfill.bg-white.pon.pos-absolute.font16.hide-display x
      .col-xs-12.col-sm-12.no-mar-pad
        .glyphicon.glyphicon-camera.file-input-button.grey-fg.padding20{style: "font-size: 65px;border: 1px dashed;"}
          = cl_image_upload_tag(:image, html: { class: "cloudinary-fileupload-wish-new file-upload-trigger", "data-height-non-source": "480" })
      .col-xs-12.col-sm-12.no-mar-pad
        .progress.progress-striped.hide-display.mbottom0.mtop5{style: "height: 10px;width:107px;"}
          .progress-bar{style: "width: 0%;"}
    .col-xs-12.col-sm-12.ptop10.j-ps-holder.height89
      .col-xs-12.col-sm-12.ptop5.grey-fg.height50
        %span.type-holder.pon.pos-absolute.full-width{style: "left: 5px;top: 32px;font-size: 15px;"}
      .prefix-holder.pon.pull-left{style: "height: 34px;border-bottom: 2px solid #732db0;padding: 6px 0px;font-size: 14px;line-height: 1.42857143;display: inline;"}
      = text_field_tag :initial, "", placeholder: "What's your wish?", class: "coco-input-field form-control inline-display pull-left ps-initial bg-white", readonly: true
      .dropdown.type-holder-dropdown
        .dropdown-menu.pos-relative.full-width
          - Showcase::DISPLAY_SHOWCASE_TYPE.each do |showcase_type|
            %li
              %a.pon{"data-id" => "#{showcase_type[1]}", "data-text" => "#{showcase_type[2]}"}
                = showcase_type[0]
      .dropdown.prefix-holder-dropdown
        .dropdown-menu.pos-relative.prefix-scrollbar.full-width{style: "max-height: 298px;overflow:hidden !important;"}
          - Showcase::WISH_PREFIX.each do |wish_prefix|
            %li
              %a.pon{"data-id" => "#{wish_prefix[1]}", "data-ptext" => "#{wish_prefix[3]}", "data-ftext" => "#{wish_prefix[4]}", "data-pplaceholder" => "#{wish_prefix[5]}", "data-fplaceholder" => "#{wish_prefix[6]}"}
                = wish_prefix[0]
                %span.grey-fg.font13
                  &nbsp;
                  %em= wish_prefix[2]
      .hide-display
        = f.text_field :showcase_type
        = f.text_field :wish_prefix
        = f.text_field :title
    .col-xs-12.col-sm-12.text-center.ptop10
      ~ f.text_area :description, placeholder: "Description", class: "form-control coco-input-field", maxlength: 25000
    .col-xs-12.col-sm-12.ptop20.pbottom10
      = f.text_field :all_tags, placeholder: "Tags (Use enter, comma or tab to separate)", class: "tm-new-input form-control tm-input-inverse tm-input-typeahead coco-input-field"
    .col-xs-12.col-sm-7.ptop10.height50
      = f.fields_for :location do |lf|
        = lf.text_field :name, placeholder: "Where", class: "form-control coco-input-field new-loc-input", maxlength: 100
    .col-xs-12.col-sm-5.ptop10.height50
      = f.text_field :target_date, placeholder: "When", class: "form-control coco-input-field dt-of-achievement bg-white", readonly: true
    .col-xs-12.col-sm-12.mtop10.text-center
      = f.submit "Wish", class: "btn cc-dark-bg white-fg weight-bold showcase-submit"
