.container-fluid.bg-white.padding0.full-height.chat-ids-holder{"data-chat-room-ids" => "#{@public_chat_rooms.map{|c| c.id}.join(',')}"}
  .col-xs-12.col-sm-3.ptop50.mob-ptop100.btn-shadow.full-height.pleft20.pright20.h-z.j-cm-conv-wrap
    .col-xs-12.col-sm-12.padding0.mbottom20.mtop20
      = text_field_tag :search_chat, "", class: "pull-left form-control padding5 pleft-10 border2", style: "height: 46px;", placeholder: "Search room.."
      .fa.fa-search.font20.pull-left{style: "margin-left: -28px;margin-top: 11px; color: #d8d8d8;"}
    - @public_chat_rooms.each_with_index do |chat_room, i|
      = render partial: "chat_rooms/chat_room_conv_card", locals: {chat_room: chat_room, i: i}
  .col-sm-6.hidden-xs#j-c-m-wrapper.ptop50.mob-ptop100.pleft0.pright0.full-height
    = render partial: "chat_rooms/chat_room", locals: {chat_room: @public_chat_rooms.first, chat_messages: @public_chat_messages}
  .col-xs-3.hidden-xs#j-c-m-rhs.ptop50.mob-ptop100.no-mar-pad.btn-shadow.full-height.h-z
    = render partial: "chat_rooms/chat_conv_rhs", locals: {chat_room: @public_chat_rooms.first}
  .j-scroll-params
    = hidden_field_tag :last_id, @msg_id
    = hidden_field_tag :room_id, @room_id

= content_for :extra_js do
  :javascript
    $(document).ready(function(){
      $('footer').css("display", "none");
      $("#chat_message_content").focus();
      $("#chat_message_content").css("height", $(".j-chat-form-wrapper").height())
      $(document).on("click", ".j-ct-conv-wrap", function(){
        $(this).closest(".j-cm-conv-wrap").find(".active").removeClass("active");
        $(this).addClass("active");
        $(this).find(".badge").hide();
        $(this).find(".badge").text("0");
        $("#j-c-m-wrapper").html("<span class='full-width inline-block text-center'><i class='fa fa-spinner fa-spin font25 cc-dark-fg' style='margin-top: 40%'></i></span>")
        $.ajax({url: "/chatrooms/"+$(this).data("chat-room-id")});
      })
      if(#{@public_chat_rooms.first.chat_messages.count} > 20){
        $("#chat_messages").on("scroll", function(){
          if($(this).scrollTop() == 0){
            $(this).off("scroll");
            $(".msg-loader").show();
            $.get("/chatrooms/get_chat_messages?room_id=#{@public_chat_rooms.first.id}&last_id=#{@public_chat_messages.first.id}");
          }
        })
      }
      $(document).on("keyup", "#search_chat", function(){
        var value = $(this).val();
        $(".j-croom-name").each(function(){
          var name = $(this).text();
          if(name.indexOf(value) < 0){
            $(this).closest(".j-ct-conv-wrap").hide();
          }else{
            $(this).closest(".j-ct-conv-wrap").show();
          }
        })
      })
    })
