- if @collection.errors.blank?
  $(".create-collect")[0].reset();
  $(".create-collect").hide();
  $(".plus-prof").show();
  var collection = $("#{j render partial: 'showcases/collection', locals: {collection: @collection}}").hide();
  $(".collection-strip").append(collection);
  $(".collection-#{@collection.id}").fadeIn('slow');
  $(".collections-count").text(parseInt($(".collections-count").text()) + 1)
- else
  $(".create-collect-err").text("#{@collection.errors.full_messages.first}");
