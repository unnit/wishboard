= content_for :title do
  -title = "Search Products - Cocociti"
= content_for :header_extra do
  .col-lg-1{style: "padding-top: 8px;padding-left: 9px;"}
    .hidden-xs
      %a.btn.btn-primary.btn-sm.pull-left.adv-button{href: "#upApp1", data: {toggle: 'collapse', parent: '#accordion'}}
        %span.glyphicon.glyphicon-filter
#re-search-pop-up.modal.fade
  .modal-dialog
    .modal-content.pop-up-mar
      .modal-header.pop-bac
        %button.close{ type: 'button', 'data-dismiss' => 'modal', 'aria-hidden' => true }
          %i.fa.fa-times
        %h4.modal-title No Item found for the specified time period.
      .modal-body
        .col-sm-12.text-center
          %h4 #{@msg}
          %br
          %button.btn.btn-primary.re-search Search Again After Updating Dates
          %br
          %br
          %br
      .clearfix
.intro-header2
  #upApp1.panel-collapse.collapse{style: "border-top:1px; border-bottom:1px solid #ccc;"}
    .panel-body.no-padding
      .search.tb5
        .container
          .row
            .col-md-12
              .form-section
                .row
                  %form
                    .col-md-3{style: "text-align:center;"}
                      .input-group.ipg
                        %b.ipg1 Price INR= #{@min_price} - #{@max_price}
                        %div
                          - value = params[:price].blank? ? "#{@min_price},#{@max_price}" : params[:price]
                          = text_field_tag :price_range, '', class: 'slider span2 input-md form-control', data: {"slider-min": "#{@min_price}", "slider-max": "#{@max_price}", "slider-step": "500", "slider-value": "[#{value}]", target: '#price'}
                    .col-md-3
                      .form-group.ipg2
                        %label.sr-only owner
                        = select_tag :ownertype, options_for_select(Product::OWNER_TYPE, params[:owner_type]), class: "form-control filter", prompt: "Booking Type", data: {target: "#owner_type"}
                    .col-md-3.ipg3
                      .form-group.ipg2
                        %label.sr-only Product Condition
                        = select_tag :product_cond, options_for_select(Product::PRODUCT_CONDITION, params[:product_condition]), prompt: "Product Condition", class: "form-control filter", data: {target: "#product_condition"}
                    .col-md-1
                      = link_to "Run Filter", "javascript:;", class: "btn btn-primary", id: "filter", style: "background-color: #e84242;border:none; border-radius: 0; margin-top: 10px;"
%div
  .row.clearfix
    .col-md-8.mob-map-view-con.pad-0
      .col-md-12.search-bread-crumbs
        .ol.breadcrumb.mbottom0.note-font-size
          = render_breadcrumbs tag: :li, separator: "&nbsp;&nbsp;<span class='glyphicon glyphicon-menu-right extra-small-font'></span>&nbsp;&nbsp;".html_safe
      .tabbale-panel-mp
        .tabbable-line-mp
          %ul.nav.nav-tabs.pad-nav
            %li.tabs-mar{class: "#{'active' if params[:tab].blank? || params[:tab] == "1"}"}
              = link_to "Popular", "javascript:;", data: {tab: '1'}, class: 'product-tab bg-white'
            %li.tabs-mar{class: "#{'active' if params[:tab] == "2"}"}
              = link_to "Low Price", "javascript:;", data: {tab: '2'}, class: 'product-tab bg-white'
            %li.tabs-mar{class: "#{'active' if params[:tab] == "3"}"}
              = link_to "High Price", "javascript:;", data: {tab: '3'}, class: 'product-tab bg-white'
            %li.tabs-mar{class: "#{'active' if params[:tab] == "4"}"}
              = link_to "New", "javascript:;", data: {tab: '4'}, class: 'product-tab bg-white'
          .tab-content.tabbable-panel-mp-height.grey-bg
            #tab-1.tab-pane.active
              - if @products.blank?
                .col-sm-12.no-mar-pad
                  %h3.text-center Ayyo, Items are not available for the selected time frame.
              - else
                - @products.each_slice(3) do |products|
                  .col-sm-12.no-mar-pad
                    - products.each do |product|
                      .col-sm-4.mob-map-view-con
                        = render partial: "product", locals: {product: product}
                .col-md-12
                  %center= paginate @products

    .col-md-4.hidden-xs.hide-tablet{style: "padding-left:0;"}
      %div{style: "padding-left: 0;"}
        - loc = params[:location]
        - loc = "India" if loc.blank?
        - @products.each do |product|
          = hidden_field_tag :map_location, product.location_address, class: "marker", data: {title: product.title, image: product.image.filename, price: product.price, path: user_product_path(product.id), lat: product.lat, lng: product.lng}

        #gmap.col-sm-12.no-mar-pad{style: "height: 600px; position: fixed !important; width: 100%; overflow: hidden;", data: {drag: "false"}}

= content_for :extra_js do
  :javascript
    $(document).ready(function(){
      msg = "#{@msg}"
      if(msg.length)
      {
        $("#re-search-pop-up").modal("show");
      }
      $(".re-search").click(function(){
        start_date_time = "#{@suggest_start_date}"
        end_date_time = "#{@suggest_end_date}"
        $("#start_date_time_header").val(start_date_time);
        $("#end_date_time_header").val(end_date_time);
        $(".search-form").submit();
      })
    })
