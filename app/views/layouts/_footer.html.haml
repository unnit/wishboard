%footer.fot.fot-mar.mar-fot{style: "display: #{@footer_visible || 'block'}"}
  .container
    .row
      .col-lg-12
        .col-md-12
          = link_to "javascript:;" do
            = image_tag "img/log/coc.png"
          .pull-right
            = link_to "https://fb.com/cocociti" do
              = image_tag "img/landing-pg-vd_assets/landing-pg-vd_assets/FB.png"
            = link_to "https://google.com/+cocociti" do
              = image_tag "img/landing-pg-vd_assets/landing-pg-vd_assets/Gplus.png"
            = link_to "https://twitter.com/cocociti" do
              = image_tag "img/landing-pg-vd_assets/landing-pg-vd_assets/Twitter.png"
          %hr{style: "width: 100%"}
        .col-md-3
          %p.fot-p Cocociti is your trusted human2human online rental marketplace. Product owners make money by sharing products and you save money by avoiding costly purchases.
        .col-md-3
          %ul.tag-ul.pull-right
            %li.tag-ul-h
              %h4.fot-li COMPANY
            %li= link_to "About", "/about", class: "tag-a"
            %li= link_to "Terms", "/terms", class: "tag-a"
            %li= link_to "Privacy", "/privacy", class: "tag-a"
            %li= link_to "Contact", "/contact", class: "tag-a"
            %li= link_to "Site Map", "/sitemap", class: "tag-a"

        .col-md-3
          %ul.tag-ul.pull-right
            %li.tag-ul-h
              %h4.fot-li COCOCARE
            %li
              %i 96 8686 0303
            %li ayyo@cocociti.com
    = link_to "#" do
      = image_tag "img/landing-pg-vd_assets/landing-pg-vd_assets/up.png", class: "pull-right fot-up-img"
    %p.copyright.text-muted.small.pull-right.fot-res &copy; #{Time.now.in_time_zone("Kolkata").strftime('%Y')} Cocociti
