.col-xs-12.col-sm-12.no-mar-pad.padding10
  .col-xs-4.col-sm-4.no-mar-pad
    .col-xs-12.col-sm-12.no-mar-pad.photo-wrapper.mbottom10.text-center{style: "overflow: hidden;height: 164px;"}
      .preview
        - if @showcase.fullfilled_image.present?
          = cl_image_tag @showcase.fullfilled_image, class: "img-responsive inline-display", height: 150, crop: :fill, gravity: :face, alt: @showcase.title
      .preview-delete-fullfill.bg-white.pon.pos-absolute.font16{class: "#{@showcase.fullfilled_image.blank? ? 'hide-display' : 'block-display'}"} x
      .col-xs-12.col-sm-12.no-mar-pad
        .glyphicon.glyphicon-camera.file-input-button.mtop20.padding20.cc-dark-fg.dotted-border{style: "font-size: 65px;display: #{@showcase.fullfilled_image.present? ? 'none': 'inline-block'};"}
          = cl_image_upload_tag(:fullfilled_image, html: { class: "cloudinary-fileupload-fullfill file-upload-trigger", "data-height": "150", "data-width": "100", "data-height-non-source": "150"  })
      .col-xs-12.col-sm-12.no-mar-pad
        .progress.progress-striped.progress.mbottom0{style: "display: none;height: 6px;width:107px;"}
          .progress-bar.progress-bar{style: "width: 0%;"}
    .col-xs-12.col-sm-12.no-mar-pad
      = f.text_field :date_of_achievement, placeholder: "When", class: "form-control coco-input-field pleft5 date-of-achievement bg-white"
  .col-xs-8.col-sm-8.text-center.ptop10
    .col-xs-12.col-sm-12.padding5{:style => "height: 198px;"}
      = f.text_area :achieved_description, placeholder: "Tell the story of fullfillment of this wish?", class: "form-control coco-input-field pleft5", maxlength: 2500, rows: 1, style: "height: 193px;"
