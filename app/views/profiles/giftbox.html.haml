= content_for :title do
  - title = "Giftbox - Cocociti"
.container-fluid.ptop50.mob-ptop100.pattern-bg{style: "min-height: 700px;"}
  .container.mtop40.padding0
    .row.no-mar-pad.mtop10
      = render "profiles/giftbox/overall_stats"
    .row.no-mar-pad.mtop10{style: "height: 400px;"}
      .col-xs-12.col-sm-6{style: "height: 100%;"}
        = render "profiles/giftbox/crounding_withdraw_request"
      .col-xs-12.col-sm-6.full-height
        = render "profiles/giftbox/crounding_withdraw_history"
    .col-sm-12.no-mar-pad.mtop10{style: "height: 400px;"}
      .col-xs-12.col-sm-6.full-height
        = render "profiles/giftbox/profile_withdraw_history"
      .col-xs-12.col-sm-6.full-height
        = render "profiles/giftbox/profile_transfers_history"


= content_for :extra_js do
  :javascript
    $(document).ready(function(){
      function LoadtransferForm(showcase_id){
        $.ajax({
              type: 'post',
              url: "/profiles/send_to_bank_form",
              data: {showcase_id: showcase_id},
              success: function(data) {}
          });
      }
      $(document).on("click", ".wdrw-btn", function(){
        LoadtransferForm($(this).attr('data-showcase-id'))
      })
    })


   
