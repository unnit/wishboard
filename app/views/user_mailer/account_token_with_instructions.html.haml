%p{style: "text-align: center;"} Welcome #{@user.email}!
%p Please activate your account email using the button below:
%br
= link_to "#{user_confirmation_url(id: @user.id, confirmation_token: @token)}", style: "text-decoration: none" do
  %span{style: "padding: 15px 60px;background-color: #05A665;color: white;font-size: 25px;"}
    Activate
%br
%br
%p
  Step 1: Update profile & start renting.
  %br
  Step 2: Create a listing and share your items with others.
  %br
  Step 3: Browse and save money by taking things on rent.
  %br
  Step 4: Like us on
  = link_to "Facebook", "www.facebook.com/cocociti"
  = "& Follow us on"
  = link_to "Twitter", "www.twitter.com/cocociti"
  to get updates and new offers.
