- users.each do |user|
  .col-sm-12.border-bt-side.no-mar-pad{style: "height: 80px;", class: "follow-set-#{user.id}"}
    .col-sm-2.no-mar-pad
      = cl_image_tag user.avatar, class: "img-circle hovercard mtop10", data: {id: user.id}, width: 40, height: 40, crop: :fill
    .col-sm-10
      %span.mtop5.pull-left.hovercard{"data-id" => "#{user.id}"}
        = (truncate user.name.titleize, length: 40)
    .col-sm-10
      = link_to user_toggle_follow_path(user), remote: true, method: :post do
        .btn.no-mar-pad.loader-out-follow-button.follow-button.btn-grey
          = submit_tag "Follow", class: "loader-button btn loader-in-follow-button padding0 grey-fg"
          .loader-effect.btn.loader-in-follow-button.grey-fg{style: "display:none;"}
            .ball-clip-rotate{style: "height:22px;"}
              %div ...
    /
      .col-sm-2.no-mar-pad
        = link_to user_toggle_follow_path(user), remote: true, method: :post do
          %i.fa.fa-user-plus.font25.grey-fg.mtop10
