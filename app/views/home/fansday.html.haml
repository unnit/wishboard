.container-fluid.padding0.wrap-3{style: "background-color: #6475dc;min-height: 500px;"}
  .container.padding0.white-fg.text-center.pbottom70
    %h1.mtop70.mbottom40
      LEARN HOW THE WORLD IS USING COCOCITI
    .col-sm-9.col-xs-12{style: "min-height: 160px"}
      %h3.mtop10 Showcase
      %h5
        Show off your likes & things you own. That awesome apparel, your achievements, things you are proud of owning, & the memories you value. Make a beautifully arranged virtual showcase at the push of a button on Cocociti.
    .col-sm-3.col-xs-12.hidden-xs{style: "min-height: 160px"}
      %img{src: "#{GLOBAL_VARIABLES[:root_url]}/assets/images/showpiece.png", height: 100}
    .col-sm-3.col-xs-12.hidden-xs{style: "min-height: 160px"}
      %img{src: "#{GLOBAL_VARIABLES[:root_url]}/assets/images/wishlist.png", height: 100}
    .col-sm-9.col-xs-12{style: "min-height: 160px"}
      %h3.mtop10 Wishlist
      %h5
        Do you wish to be great? Then begin by being. Wish it, believe it, and it will be so. Add your wishes & goals to Cocociti and let the world wish you luck with it.
    .col-sm-9.col-xs-12.text-center{style: "min-height: 160px"}
      %h3.mtop10 Discover
      %h5 They say world is a wonderful place. We say, explore it. Browse through wishes, people and their showcases on Cocociti.
    .col-sm-3.col-xs-12.hidden-xs{style: "min-height: 160px"}
      %img{src: "#{GLOBAL_VARIABLES[:root_url]}/assets/images/discover-coco.png", height: 100}
    .col-xs-12.col-sm-12
      .btn.btn-lg.mtop10.fan-box-btn
        View a Sample Profile

= content_for :extra_js do
  :javascript
    $(document).ready(function(){
      $(window).scroll(function(){
        if($(window).scrollTop() >= ($(".wrap-2").offset().top) - 400){
          $(".q-box-1").fadeIn(500,function(){
            $(".q-box-2").fadeIn(500,function(){
              $(".q-box-3").fadeIn(500, function(){
                $(".celeb-wrap").fadeIn();
              });
            })
          })
        }
      })
      var root = $('html, body');
      $(".fn-ln-mr").click(function(){
        root.animate({
            scrollTop: $(".wrap-2").offset().top - 53
            }, 500);
        return false;
      })
    })
