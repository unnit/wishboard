.col-xs-12.col-sm-12
  .col-sm-1
    %span= i
    %span.pull-right= image_tag product.image, size: "32x32"
  .col-sm-2= product.title
  .col-sm-1
    .col-xs-3.no-mar-pad.visible-xs-block ID
    .col-xs-9.no-mar-pad= product.id
  .col-sm-2
    .col-xs-3.no-mar-pad.visible-xs-block
      %strong Category
    .col-xs-9.no-mar-pad= product.category_name
  .col-sm-1.no-mar-pad
    .col-xs-3.no-mar-pad.visible-xs-block
      %strong Price
    .col-xs-9.no-mar-pad
      %i.fa.fa-rupee
      = product.price
  .col-sm-1.no-mar-pad
    .col-xs-3.no-mar-pad.visible-xs-block
      %strong Shipping
    .col-xs-9.no-mar-pad
      %i.fa.fa-rupee
      = product.ship_price
  .col-sm-1
    .col-xs-3.no-mar-pad.visible-xs-block
      %strong Status
    .col-xs-9.no-mar-pad.avail
      = product.available==true ? "Available" : "Unavailable"
  .col-sm-1
    .col-xs-3.no-mar-pad.visible-xs-block
      %strong Orders
    .col-xs-9= product.transactions.count
  .col-sm-1.text-right
    = link_to edit_product_path(product), class: "btn btn-sm btn-success" do
      %span.glyphicon.glyphicon-pencil
  .col-sm-1
    .col-xs-3.no-mar-pad.visible-xs-block
      %strong On/Off
    .col-xs-9
      = check_box_tag :available, product.available,  product.available?, class: "available-switch", data: {id: product.id}
      %span.update-msg{style: "color: green;"}
      %span.update-error{style: "color: red;"}