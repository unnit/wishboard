= content_for :title do
  -title = "Payment Successful"
.container-fluid.ptop50.mob-ptop100.min-height1000
  .col-xs-12.col-sm-4.col-sm-offset-4.cc-dark-fg-border.mtop20.text-center.padding0.pbottom20.border2.black80-fg
    -if @cocotransfer.showcase_transfer?
      %h3.mtop0.padding15.bg-light-grey.border-bt-side= @cocotransfer.transferable.title
    -else
      %h3.mtop0.padding15.bg-light-grey.border-bt-side= @cocotransfer.transferable.name
    %i.fa.fa-check-circle.green-fg.mtop10{style: "font-size: 60px;"}
    %h3.mtop5 Rs. #{@cocotransfer.total_amount}
    %h4.font22.mtop20.mbottom0 Boom De Yaada!
    %h5.font-medium.mtop10 Your payment is successful.
    %h4.mtop100 Transaction ID: #{@cocotransfer.txnid}
    %span.font12 #{@cocotransfer.updated_at.strftime('%H:%M, %d-%b-%Y, %a')}
    -if @cocotransfer.showcase_transfer?
      %span
        .shareShowcaseRoundIcons{"data-id" => "#{@cocotransfer.transferable.try(:id)}"}
      = link_to slug_showcase_path(@cocotransfer.transferable.slug, @cocotransfer.transferable) do
        .btn.btn-md.btn-v-outline.mtop20.transition-effect
          Gift Again
    -else
      %span
        .shareProfilePayRoundIcons{"data-id" => "#{@cocotransfer.transferable.try(:id)}"}
      = link_to myprofile_path(@cocotransfer.transferable.try(:profile).try(:slug)) do
        .btn.btn-md.btn-v-outline.mtop20.transition-effect
          Gift Again

  .col-xs-12.col-md-12.text-right.mtop10
    = link_to "Back to Home", root_path, class: "cc-dark-fg"
= content_for :extra_js do
  :javascript
    -if  @cocotransfer.showcase_transfer?
      $(document).ready(function(){
        obj = {"longUrl" : "https://www.cocociti.com/wish/#{@cocotransfer.transferable.id}"}
        $.ajax({url: "https://content.googleapis.com/urlshortener/v1/url?key=AIzaSyBKouCyRuExAspdTSgCjQ1825AbI_8Fank&alt=json", type: 'POST', contentType: "application/json", data: JSON.stringify(obj), success: function(data){
          $(".shareShowcaseRoundIcons").jsSocials({
            url: data["id"],
            text: "I just backed #{@cocotransfer.showcase_title} @Cocociti",
            showLabel: false,
            showCount: false,
            shares: ["twitter", "facebook", "googleplus", "linkedin", "pinterest", "whatsapp"]
          });
        }});
      })
